# Supabase — project: vv-portfolio
# Find these in the Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Required for: resume PDF download signed URLs.
# Never expose this in the browser; no NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Enables AI resume parsing + sync suggestions in the admin.
# Set EITHER of these; Gemini takes precedence when both are present.
# Without one, the resume module falls back to manual entry.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash   # optional override (e.g. gemini-2.5-pro)
ANTHROPIC_API_KEY=

# Canonical site URL used for metadata, sitemap, and OG images.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
